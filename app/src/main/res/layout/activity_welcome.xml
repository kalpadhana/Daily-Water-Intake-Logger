<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/welcome_background"
    tools:context=".WelcomeActivity">
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/fb" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"/>
    <!-- Optional dark overlay for better text readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000"/>

    <!-- Modern Bottom Sheet Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardCornerRadius="35dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_modern_card">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build a Healthy Habit — One Sip at a Time"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#0B1B3F"
                android:lineSpacingExtra="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Simple, clean and effective app to keep your water intake right."
                android:textSize="15sp"
                android:textColor="#64748B"
                android:lineSpacingExtra="3dp"/>

            <!-- Spacer so button doesn't overlap text -->
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabNext"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="2dp"
                app:backgroundTint="#000000"
                app:elevation="12dp"
                app:rippleColor="#80FFFFFF"
                app:srcCompat="@drawable/ic_arrow_forward"
                app:tint="@android:color/white" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Floating Arrow Button -->
</androidx.constraintlayout.widget.ConstraintLayout>