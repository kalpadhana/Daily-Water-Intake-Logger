<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft modern gradient -->
    <gradient
        android:startColor="#E6F4FF"
        android:endColor="#F8FBFF"
        android:angle="90"/>

    <!-- Smooth rounded corners -->
    <corners android:radius="28dp"/>

    <!-- Subtle border -->
    <stroke
        android:width="1dp"
        android:color="#CFE8FF"/>

    <!-- Inner padding -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp"/>

</shape>